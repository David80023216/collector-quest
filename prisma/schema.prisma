// Collector Quest - Prisma Schema
// PostgreSQL database with NextAuth support

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserRole {
  USER
  ADMIN
}

enum UserPlan {
  FREE
  PRO
}

enum MissionScope {
  DAILY
  WEEKLY
}

enum MissionCategory {
  LOGIN_CLAIM
  TRIVIA
  POLL_VOTE
  STREAK
  PACK_OPEN
  COMMUNITY_ACTION
  PRIZE_PAGE_VISIT
  LEADERBOARD_VISIT
  REDEMPTION_ACTION
}

enum MissionDifficulty {
  EASY
  MEDIUM
  HARD
}

enum LedgerTransactionType {
  DAILY_REWARD
  MISSION_REWARD
  PACK_REWARD
  STREAK_BONUS
  STORE_PURCHASE
  STORE_REDEMPTION
  FREE_ENTRY
  ADMIN_GRANT
  DRAWING_ENTRY
  BADGE_REWARD
  COMMUNITY_BONUS
}

enum RewardType {
  ENTRIES
  POINTS
  STREAK_BOOST
  BONUS_PACK
  REWARD_TOKEN
}

enum DrawingStatus {
  UPCOMING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  PAST_DUE
  TRIALING
}

// ─── Auth Models (NextAuth) ──────────────────────────────────────────────────

model User {
  id                 String    @id @default(cuid())
  name               String?
  email              String?   @unique
  emailVerified      DateTime?
  hashedPassword     String?
  image              String?
  role               UserRole  @default(USER)
  plan               UserPlan  @default(FREE)
  entries            Int       @default(0)
  points             Int       @default(0)
  currentStreak      Int       @default(0)
  longestStreak      Int       @default(0)
  lastStreakDate     DateTime?
  totalContributions Int       @default(0)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  // Relations
  accounts               Account[]
  sessions               Session[]
  subscription           Subscription?
  missionCompletions     MissionCompletion[]
  dailyRewardClaims      DailyRewardClaim[]
  triviaResponses        TriviaResponse[]
  pollResponses          PollResponse[]
  rewardPackOpens        RewardPackOpen[]
  userInventory          UserInventory[]
  userLedger             UserLedger[]
  communityContributions CommunityContribution[]
  userBadges             UserBadge[]
  storeRedemptions       StoreRedemption[]
  drawingWins            DrawingWinner[]
  drawingsWon            Drawing[]             @relation("DrawingWinner")

  @@index([email])
  @@index([plan])
  @@index([entries])
  @@index([points])
  @@index([currentStreak])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime
  type       String   @default("email")

  @@unique([identifier, token])
}

// ─── Subscription ────────────────────────────────────────────────────────────

model Subscription {
  id                   String             @id @default(cuid())
  userId               String             @unique
  stripeCustomerId     String?
  stripeSubscriptionId String?
  stripePriceId        String?
  status               SubscriptionStatus
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@index([stripeSubscriptionId])
}

// ─── Missions ────────────────────────────────────────────────────────────────

model Mission {
  id                String            @id @default(cuid())
  title             String
  description       String
  category          MissionCategory
  difficulty        MissionDifficulty
  scope             MissionScope
  entriesReward     Int               @default(0)
  pointsReward      Int               @default(0)
  packReward        Boolean           @default(false)
  contributionValue Int               @default(0)
  rotationDay       Int? // For daily missions: 1-180
  rotationWeek      Int? // For weekly missions: 1-26
  monthlyThemeId    String?
  isActive          Boolean           @default(true)
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  monthlyTheme MonthlyTheme?       @relation(fields: [monthlyThemeId], references: [id], onDelete: SetNull)
  completions  MissionCompletion[]

  @@index([category])
  @@index([scope])
  @@index([isActive])
  @@index([rotationDay])
  @@index([rotationWeek])
  @@index([monthlyThemeId])
}

model MissionCompletion {
  id          String   @id @default(cuid())
  uniqueKey   String   @unique // Format: ${userId}_${missionId}_${dateString}
  userId      String
  missionId   String
  completedAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  mission Mission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([missionId])
  @@index([userId, completedAt])
}

// ─── Daily Rewards ───────────────────────────────────────────────────────────

model DailyRewardClaim {
  id             String   @id @default(cuid())
  userId         String
  claimedAt      DateTime @default(now())
  claimDate      String // YYYY-MM-DD format
  entriesAwarded Int
  pointsAwarded  Int
  streakDay      Int
  packAwarded    Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, claimDate])
  @@index([userId])
  @@index([claimDate])
}

// ─── Monthly Themes ──────────────────────────────────────────────────────────

model MonthlyTheme {
  id          String   @id @default(cuid())
  name        String
  description String?
  month       Int // 1-12
  year        Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())

  missions        Mission[]
  triviaQuestions TriviaQuestion[]

  @@index([month, year])
  @@index([isActive])
}

// ─── Trivia ──────────────────────────────────────────────────────────────────

model TriviaQuestion {
  id            String   @id @default(cuid())
  question      String
  optionA       String
  optionB       String
  optionC       String
  optionD       String
  correctAnswer String // A, B, C, or D
  explanation   String?
  category      String?
  themeId       String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  theme     MonthlyTheme?   @relation(fields: [themeId], references: [id], onDelete: SetNull)
  responses TriviaResponse[]

  @@index([isActive])
  @@index([category])
  @@index([themeId])
}

model TriviaResponse {
  id             String   @id @default(cuid())
  uniqueKey      String   @unique // Format: ${userId}_${questionId}_${dateString}
  userId         String
  questionId     String
  selectedAnswer String
  isCorrect      Boolean
  answeredAt     DateTime @default(now())

  user     User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  question TriviaQuestion @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([questionId])
  @@index([userId, answeredAt])
}

// ─── Polls ───────────────────────────────────────────────────────────────────

model PollQuestion {
  id        String    @id @default(cuid())
  question  String
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  closesAt  DateTime?

  options   PollOption[]
  responses PollResponse[]

  @@index([isActive])
}

model PollOption {
  id        String @id @default(cuid())
  pollId    String
  text      String
  voteCount Int    @default(0)

  poll      PollQuestion   @relation(fields: [pollId], references: [id], onDelete: Cascade)
  responses PollResponse[]

  @@index([pollId])
}

model PollResponse {
  id       String   @id @default(cuid())
  userId   String
  pollId   String
  optionId String
  votedAt  DateTime @default(now())

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  poll   PollQuestion @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PollOption   @relation(fields: [optionId], references: [id], onDelete: Cascade)

  @@unique([userId, pollId])
  @@index([userId])
  @@index([pollId])
}

// ─── Reward Packs ────────────────────────────────────────────────────────────

model RewardPackDefinition {
  id          String   @id @default(cuid())
  name        String
  description String?
  rarity      String   @default("standard")
  imageColor  String   @default("#e2b714")
  isActive    Boolean  @default(true)
  proOnly     Boolean  @default(false)
  createdAt   DateTime @default(now())

  rewards RewardPackReward[]
  opens   RewardPackOpen[]

  @@index([isActive])
}

model RewardPackReward {
  id               String     @id @default(cuid())
  packDefinitionId String
  rewardType       RewardType
  rewardValue      Int
  weight           Int // For weighted random selection
  label            String
  description      String?
  rarity           String     @default("common")

  packDefinition RewardPackDefinition @relation(fields: [packDefinitionId], references: [id], onDelete: Cascade)

  @@index([packDefinitionId])
}

model RewardPackOpen {
  id               String     @id @default(cuid())
  userId           String
  packDefinitionId String
  rewardType       RewardType
  rewardValue      Int
  rewardLabel      String
  openedAt         DateTime   @default(now())

  user           User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  packDefinition RewardPackDefinition @relation(fields: [packDefinitionId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([packDefinitionId])
  @@index([userId, openedAt])
}

// ─── User Inventory ──────────────────────────────────────────────────────────

model UserInventory {
  id         String   @id @default(cuid())
  userId     String
  itemType   String
  itemId     String?
  quantity   Int      @default(1)
  acquiredAt DateTime @default(now())
  source     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([userId, itemType])
}

// ─── User Ledger ─────────────────────────────────────────────────────────────

model UserLedger {
  id              String                @id @default(cuid())
  userId          String
  transactionType LedgerTransactionType
  entriesChange   Int                   @default(0)
  pointsChange    Int                   @default(0)
  description     String
  referenceId     String?
  createdAt       DateTime              @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId])
  @@index([transactionType])
  @@index([referenceId])
}

// ─── Community ───────────────────────────────────────────────────────────────

model CommunityContribution {
  id            String   @id @default(cuid())
  uniqueKey     String?  @unique
  userId        String
  actionType    String
  value         Int      @default(1)
  contributedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([contributedAt])
  @@index([actionType])
}

model CommunityMilestone {
  id                String    @id @default(cuid())
  title             String
  description       String?
  threshold         Int
  rewardDescription String
  isUnlocked        Boolean   @default(false)
  unlockedAt        DateTime?
  sortOrder         Int       @default(0)

  @@index([isUnlocked])
  @@index([sortOrder])
}

// ─── Prizes & Drawings ───────────────────────────────────────────────────────

model PrizeTier {
  id             String  @id @default(cuid())
  minSubscribers Int
  maxSubscribers Int?
  prizeValue     Int
  label          String
  isActive       Boolean @default(true)
  sortOrder      Int     @default(0)

  @@index([isActive])
  @@index([sortOrder])
}

model Prize {
  id         String   @id @default(cuid())
  title      String
  description String?
  value      String
  prizeType  String   @default("digital")
  drawingId  String?
  imageColor String?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  drawing Drawing? @relation(fields: [drawingId], references: [id], onDelete: SetNull)

  @@index([isActive])
  @@index([drawingId])
}

model Drawing {
  id               String        @id @default(cuid())
  title            String
  description      String?
  drawDate         DateTime
  status           DrawingStatus @default(UPCOMING)
  prizeDescription String
  prizeValue       Int?
  winnerId         String?
  cardImageUrl     String?
  cardTitle        String?
  cardPlayer       String?
  cardYear         String?
  cardBrand        String?
  cardGrade        String?
  cardNumber       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  winner  User?           @relation("DrawingWinner", fields: [winnerId], references: [id], onDelete: SetNull)
  winners DrawingWinner[]
  prizes  Prize[]

  @@index([status])
  @@index([drawDate])
  @@index([winnerId])
}

model DrawingWinner {
  id               String   @id @default(cuid())
  drawingId        String
  userId           String
  displayName      String
  prizeDescription String
  prizeValue       Int?
  wonAt            DateTime @default(now())
  claimed          Boolean  @default(false)

  drawing Drawing @relation(fields: [drawingId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([drawingId])
  @@index([userId])
}

// ─── Free Entry (AMOE) ──────────────────────────────────────────────────────

model FreeEntrySubmission {
  id              String   @id @default(cuid())
  userId          String?
  name            String
  email           String
  submittedAt     DateTime @default(now())
  submissionDate  String // YYYY-MM-DD format
  ipAddress       String?
  entriesGranted  Int      @default(1)

  @@unique([email, submissionDate])
  @@index([email])
  @@index([submissionDate])
}

// ─── Badges ──────────────────────────────────────────────────────────────────

model Badge {
  id            String   @id @default(cuid())
  name          String
  description   String?
  icon          String
  requirement   String
  requiredValue Int
  category      String
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())

  userBadges UserBadge[]

  @@index([category])
  @@index([isActive])
}

model UserBadge {
  id        String   @id @default(cuid())
  userId    String
  badgeId   String
  awardedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
  @@index([userId])
  @@index([badgeId])
}

// ─── Store ───────────────────────────────────────────────────────────────────

model StoreItem {
  id          String   @id @default(cuid())
  title       String
  description String?
  pointsCost  Int
  itemType    String
  itemValue   Int      @default(1)
  imageColor  String?
  inventory   Int?
  isActive    Boolean  @default(true)
  proOnly     Boolean  @default(false)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())

  redemptions StoreRedemption[]

  @@index([isActive])
  @@index([sortOrder])
}

model StoreRedemption {
  id          String   @id @default(cuid())
  userId      String
  storeItemId String
  pointsSpent Int
  redeemedAt  DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  storeItem StoreItem @relation(fields: [storeItemId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([storeItemId])
}

// ─── Admin Settings ──────────────────────────────────────────────────────────

model AdminSetting {
  id          String   @id @default(cuid())
  key         String   @unique
  value       String
  description String?
  updatedAt   DateTime @updatedAt

  @@index([key])
}
